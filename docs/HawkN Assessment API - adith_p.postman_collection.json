        {
          "name": "Create Transfer — REQUEST",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_branch\": \"<from_branch_uuid>\",\n  \"to_branch\": \"<to_branch_uuid>\",\n  \"product_sku\": \"<product_sku>\",\n  \"quantity\": 10,\n  \"transfer_type\": \"REQUEST\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/transfers/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "transfers",
                ""
              ]
            },
            "description": "Create a REQUEST transfer. Must be authenticated as the admin of the to_branch. The admin of the from_branch will be responsible for approving."
          },
          "response": []
        },
