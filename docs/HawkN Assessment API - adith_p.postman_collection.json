                },
                {
                  "key": "product__sku",
                  "value": "",
                  "description": "Filter by product SKU",
                  "disabled": true
                }
              ]
            },
            "description": "Returns a paginated list of all stock transfers. Supports filtering by status, branch code, and product SKU."
