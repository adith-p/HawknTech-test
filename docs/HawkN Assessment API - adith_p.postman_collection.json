                  "disabled": true
                },
                {
                  "key": "from_branch__code",
                  "value": "",
                  "description": "Filter by from_branch code e.g. BR123ABC",
                  "disabled": true
                },
                {
                  "key": "to_branch__code",
                  "value": "",
                  "description": "Filter by to_branch code e.g. BR456DEF",
